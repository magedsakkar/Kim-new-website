# Copy this file to .env.local and fill in your values
# Never commit .env.local

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Site URL (used for metadata / sitemap)
NEXT_PUBLIC_SITE_URL=https://kim.org.tr

# Resend API key (for contact form)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Contact email recipient (server-side, for API route)
CONTACT_EMAIL=info@kim.org.tr

# Public contact email (shown in UI)
NEXT_PUBLIC_CONTACT_EMAIL=info@crossculturalcenter.org

# Digital library PDF base URL
NEXT_PUBLIC_LIBRARY_BASE_URL=https://panel.crossculturalcenter.org/storage/book-pdfs/
